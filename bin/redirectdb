#!/usr/bin/env bash
set -euo pipefail

DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
CONFIG_FILE="${DIR}/../../config.cfg"
SCRIPT_BASE="${DIR}/../db"

usage() {
  echo "Usage:"
  echo "  $0 create <dbname>"
  echo "  $0 backup <dbname> <filename>"
  echo "  $0 restore <dbname> <filename>"
  echo "  $0 migrate <dbname_src> <dbname_dst> <scripts...>"
}

ini_get_mysql_value() {
  local key="$1"
  awk -v key="$key" '
    /^\[mysql\]/ { section=1; next }
    /^\[/ { section=0 }
    section == 1 {
      line=$0
      gsub(/^[ \t]+|[ \t]+$/, "", line)
      if (line ~ /^#/ || line ~ /^;/ || line == "") next
      pos=index(line, "=")
      if (pos == 0) next
      k=substr(line, 1, pos-1)
      v=substr(line, pos+1)
      gsub(/^[ \t]+|[ \t]+$/, "", k)
      gsub(/^[ \t]+|[ \t]+$/, "", v)
      if (k == key) {
        print v
        exit
      }
    }
  ' "${CONFIG_FILE}"
}

MYSQL_HOST="$(ini_get_mysql_value "host")"
MYSQL_USER="$(ini_get_mysql_value "user")"
MYSQL_PASS="$(ini_get_mysql_value "passwd")"

if [[ -z "${MYSQL_HOST}" || -z "${MYSQL_USER}" ]]; then
  echo "missing mysql host/user in ${CONFIG_FILE}" >&2
  exit 1
fi

mysql_base_args() {
  local -a args=(--host="${MYSQL_HOST}" --user="${MYSQL_USER}")
  if [[ -n "${MYSQL_PASS}" ]]; then
    args+=(--password="${MYSQL_PASS}")
  fi
  printf '%s\n' "${args[@]}"
}

run_mysql_exec() {
  local query="$1"
  local -a args=()
  while IFS= read -r a; do args+=("$a"); done < <(mysql_base_args)
  mysql "${args[@]}" --execute="${query}"
}

run_mysql_file() {
  local dbname="$1"
  local filename="$2"
  local -a args=()
  while IFS= read -r a; do args+=("$a"); done < <(mysql_base_args)
  mysql "${args[@]}" "${dbname}" < "${filename}"
}

run_mysqldump_backup() {
  local dbname="$1"
  local filename="$2"
  local -a args=()
  while IFS= read -r a; do args+=("$a"); done < <(mysql_base_args)
  mysqldump "${args[@]}" --compact "${dbname}" > "${filename}"
}

create_db() {
  local dbname="$1"
  run_mysql_exec "drop database if exists ${dbname};"
  run_mysql_exec "create database ${dbname};"
  run_mysql_file "${dbname}" "${SCRIPT_BASE}/init.sql"
}

backup_db() {
  local dbname="$1"
  local filename="$2"
  run_mysqldump_backup "${dbname}" "${filename}"
}

restore_db() {
  local dbname="$1"
  local filename="$2"
  run_mysql_exec "drop database if exists ${dbname};"
  run_mysql_exec "create database ${dbname};"
  run_mysql_exec "set global foreign_key_checks=0;"
  run_mysql_file "${dbname}" "${filename}"
  run_mysql_exec "set global foreign_key_checks=1;"
}

migrate_db() {
  local dbname_src="$1"
  local dbname_dst="$2"
  shift 2
  local scripts=("$@")
  local database_src_temp="redirect_backup"
  local backup_filename="${HOME}/temp-redirect-backup"

  backup_db "${dbname_src}" "${backup_filename}"
  restore_db "${database_src_temp}" "${backup_filename}"

  run_mysql_exec "drop database if exists ${dbname_dst};"
  run_mysql_exec "create database ${dbname_dst};"
  run_mysql_exec "set global foreign_key_checks=0;"
  run_mysql_file "${dbname_dst}" "${SCRIPT_BASE}/init.sql"
  for script in "${scripts[@]}"; do
    run_mysql_file "${dbname_dst}" "${SCRIPT_BASE}/${script}"
  done
  run_mysql_exec "set global foreign_key_checks=1;"
}

if [[ $# -lt 1 ]]; then
  usage
  exit 1
fi

action="$1"
shift

case "${action}" in
  create)
    [[ $# -eq 1 ]] || { usage; exit 1; }
    create_db "$1"
    ;;
  backup)
    [[ $# -eq 2 ]] || { usage; exit 1; }
    backup_db "$1" "$2"
    ;;
  restore)
    [[ $# -eq 2 ]] || { usage; exit 1; }
    restore_db "$1" "$2"
    ;;
  migrate)
    [[ $# -ge 3 ]] || { usage; exit 1; }
    migrate_db "$@"
    ;;
  *)
    usage
    exit 1
    ;;
esac
